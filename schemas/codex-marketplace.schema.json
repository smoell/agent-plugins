{
  "$id": "https://awslabs.github.io/agent-plugins/schemas/codex-marketplace.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Schema for Codex marketplace registry files",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "interface": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "displayName": {
          "type": "string"
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "source",
          "policy",
          "category"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "source": {
            "type": "object",
            "required": [
              "source",
              "path"
            ],
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "local"
                ]
              },
              "path": {
                "type": "string"
              }
            }
          },
          "policy": {
            "type": "object",
            "required": [
              "installation",
              "authentication"
            ],
            "properties": {
              "installation": {
                "type": "string",
                "enum": [
                  "NOT_AVAILABLE",
                  "AVAILABLE",
                  "INSTALLED_BY_DEFAULT"
                ]
              },
              "authentication": {
                "type": "string",
                "enum": [
                  "ON_INSTALL",
                  "ON_USE"
                ]
              }
            }
          },
          "category": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "name",
    "plugins"
  ]
}
